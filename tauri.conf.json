{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicBee",
  "version": "0.1.0",
  "identifier": "com.musicbeetauri.app",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MusicBee",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "icon": ["icons/icon.png"],
    "shortDescription": "",
    "longDescription": ""
  }
}
